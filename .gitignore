/target
**/*.rs.bk

# Local Cargo cache (large registry/git blobs not to be committed)
/.cargo/

# Huge stress-test fixtures (built from corpus, not source-of-truth)
samples/tsumi-to-batsu-x100.afm

# VS Code extension build artefacts
editors/vscode/node_modules/
editors/vscode/out/
editors/vscode/*.vsix

# Editor state
.idea/
*.swp

# VS Code per-folder settings: ignore everything by default, but keep
# the files we ship for Extension Host debugging and the sample
# workspace wiring.
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json
