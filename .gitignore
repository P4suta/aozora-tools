/target
**/*.rs.bk

# Local Cargo cache (large registry/git blobs not to be committed).
# `.cargo/config.toml` is project-level cargo config and IS tracked —
# only the runtime cache directories below should stay out of the repo.
/.cargo/registry/
/.cargo/git/
/.cargo/.global-cache
/.cargo/.package-cache
/.cargo/.package-cache-mutate
/.cargo/.crates.toml
/.cargo/.crates2.json

# Huge stress-test fixtures (built from corpus, not source-of-truth)
samples/tsumi-to-batsu-x100.afm

# VS Code extension build artefacts
editors/vscode/node_modules/
editors/vscode/out/
editors/vscode/*.vsix
# Per-platform `.vsix` archives produced by `cargo xtask vsix-all`.
# They're release outputs (1-2 MiB each, ~14 MiB total for 8 targets);
# the Marketplace serves the canonical copies, so the working tree
# never tracks them.
editors/vscode/dist-vsix/
# Bundled aozora-lsp binary copied in by the release workflow / local
# `cargo build` for vsix packaging. Per-platform binary, never source.
editors/vscode/server/

# Stray object files from tree-sitter's `cc` build script (the
# generator emits them next to the source on some hosts).
crates/tree-sitter-aozora/*.o

# Editor state
.idea/
*.swp

# VS Code per-folder settings: ignore everything by default, but keep
# the files we ship for Extension Host debugging and the sample
# workspace wiring.
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json
